{
  "name": "@weazy-pms/infra",
  "version": "1.0.0",
  "description": "AWS CDK Infrastructure for Weazy PMS",
  "private": true,
  "scripts": {
    "build":  "tsc",
    "watch":  "tsc --watch",
    "synth":  "npx cdk synth",
    "deploy": "npx cdk deploy --all --require-approval never",
    "diff":   "npx cdk diff",
    "destroy":"npx cdk destroy --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.180.0",
    "constructs": "^10.4.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "aws-cdk": "^2.1119.0",
    "typescript": "^5.8.3"
  }
}
